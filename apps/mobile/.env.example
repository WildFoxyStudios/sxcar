# Copia a .env (gitignored) para sobreescribir el backend en desarrollo.
# Por defecto la app usa el backend público https://api.turnend.win (Cloudflare Tunnel).

# API local en esta máquina:
# EXPO_PUBLIC_API_URL=http://localhost:8081

# API desde un dispositivo físico apuntando a tu PC en la LAN:
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8081
