{
  "db_name": "PostgreSQL",
  "query": "SELECT u.id, u.email::text as \"email!\",\n                  u.email_verified, u.status, u.role, u.created_at\n           FROM users u\n           LEFT JOIN profiles p ON p.user_id = u.id\n           WHERE u.email ILIKE '%' || $1 || '%' OR p.display_name ILIKE '%' || $1 || '%'\n           ORDER BY u.created_at DESC\n           LIMIT $2 OFFSET $3",
