# proyecto-X — secretos de runtime del backend (PRODUCCIÓN).
# Copia a `infra/.env` (gitignored) y RELLENA. Nunca commitear el .env real.
# El .env se despliega a la instancia en /opt/proyectox/.env (chmod 600, root).

# --- Postgres (Neon) ---
# String POOLED (PgBouncer, host con "-pooler") para la API en runtime:
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/proyectox?sslmode=require
# String DIRECTO (sin "-pooler") para migraciones/DDL:
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/proyectox?sslmode=require

# --- Auth ---
# Genera uno fuerte: `openssl rand -base64 48`
JWT_SECRET=CHANGE_ME_genera_con_openssl_rand_base64_48

# --- Redis (interno a docker compose; NO exponer) ---
REDIS_URL=redis://redis:6379

# --- Cloudflare R2 (S3-compatible) ---
# Crea un R2 API Token (Object Read & Write) scoped a los buckets proyectox-*.
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_MEDIA=proyectox-media
R2_BUCKET_PRIVATE=proyectox-private
R2_BUCKET_VERIFICATION=proyectox-verification
# Endpoint S3 de R2 (usa tu account id):
R2_S3_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com

# --- API runtime ---
# Imagen del contenedor de la API (GHCR) o build local en la instancia:
API_IMAGE=ghcr.io/OWNER/proyectox-api:latest
# Puerto interno del binario axum:
API_PORT=8080
# Origen público (temporal: DNS de EC2; luego el dominio):
PUBLIC_API_ORIGIN=http://CHANGE_ME.compute-1.amazonaws.com
